# Low-privilege app role (NOBYPASSRLS) — used for all regular request traffic.
# Row-level security actually applies to this connection.
DATABASE_URL=postgresql://ems_app.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:6543/postgres

# Owner/superuser role — used only for schema DDL (init_db() on boot, Alembic
# migrations). Falls back to DATABASE_URL if unset, for environments that
# haven't split the two roles yet.
ADMIN_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:6543/postgres

JWT_SECRET=replace-with-a-long-random-string

# Sentry error tracking (optional). Get DSN from https://sentry.io/
# Leave empty to disable error tracking.
SENTRY_DSN=

# Sentry sampling rates (0.0-1.0). Adjust based on traffic volume.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.01

# Environment name (development/staging/production)
ENVIRONMENT=development
